# packages/api — Environment Variables
# Copy this to .env and fill in real values

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=file:./data/previa.db
# Prod: DATABASE_URL=postgresql://user:password@host:5432/previa

# ── JWT / Auth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRATION=24h
COOKIE_SECURE=false   # set to true in production (HTTPS only)

# ── External API Tokens (NEVER in the frontend) ───────────────
GEORISQUES_V2_TOKEN=
BDNB_API_KEY=

# ── Uploads ───────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
